  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EndingInteractable
  endingText: "I hid from them.\r\ni hid the debt \r\nthe drugs \r\nmy secret \r\n\r\nI
    was too ashamed to tell them the truth. \r\nI thought if they knew, they would
    leave. \r\nbut they already did,  so I left. \r\n"
